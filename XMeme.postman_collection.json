      "name": "Create Memes",
      "item": [
        {
          "name": "Create Meme 1 - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"memeId1\", jsonData.id);",
                  "    pm.test(\"Meme created successfully\", function () {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "    pm.test(\"Response has id\", function () {",
                  "        pm.expect(jsonData.id).to.not.be.undefined;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Alice Johnson\",\n    \"url\": \"https://example.com/meme1.jpg\",\n    \"caption\": \"When the build finally passes after 10 attempts\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/memes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "memes"
              ]
            },
            "description": "Creates a new meme with valid data. Returns 201 Created with the meme ID."
          },
